# =============================================================================
# AI-TA Environment Variables
# Copy this file to .env and fill in the values for local development.
# =============================================================================

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
PRODUCTION=0                          # 0 = development, 1 = production

# --- Admin ---
ADMIN_EMAIL=admin@example.com         # Platform administrator email

# --- Firestore ---
FIRESTORE_DATABASE_ID=your-firestore-db-id
SERVICE_ACCOUNT_EMAIL=sa@your-project.iam.gserviceaccount.com
FIRESTORE_CLIENT_ID=123456789

# --- Secret Manager key names ---
# These are the *names* of secrets stored in Google Secret Manager.
OAUTH_CLIENT_ID_KEY_NAME=oauth-client-id
OAUTH_CLIENT_SECRET_KEY_NAME=oauth-client-secret
SIGNING_SECRET_KEY_NAME=signing-secret-key
FIRESTORE_PRIVATE_KEY_ID_KEY_NAME=firestore-private-key-id
FIRESTORE_PRIVATE_KEY_KEY_NAME=firestore-private-key

# --- Optional: Gemini API key ---
# Leave empty to use Vertex AI with service account auth instead.
GEMINI_API_KEY_NAME=

# --- Optional: SendGrid email ---
SENDGRID_FROM_EMAIL=noreply@example.com

# --- Optional: OAuth redirect (for development with ngrok) ---
# OAUTH_REDIRECT_URI=https://yoursubdomain.ngrok-free.app/callback

# --- Optional: Cloud Storage ---
# BUCKET_NAME=your-bucket-name        # Defaults to {project_id}-bucket
